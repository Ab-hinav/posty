---
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION } from '../consts';
import { collectTags, difficultyBadge, getPublishedArticles, readingTime } from '@/lib/articles';

const articles = await getPublishedArticles();
const latest = articles.slice(0, 3);
const topics = collectTags(articles).slice(0, 6);
---

<Layout bodyClass="dotted-bg">
	<main class="mx-auto w-full max-w-[800px] flex-grow px-md py-xl md:px-gutter md:py-24">
		<!-- Hero -->
		<header
			class="relative mb-24 overflow-hidden rounded-xl border border-outline-variant bg-surface-container-lowest p-8 shadow-sm"
		>
			<div class="absolute right-0 top-0 h-32 w-32 rounded-bl-full bg-primary-container opacity-20"></div>
			<h1
				class="relative z-10 mb-md font-headline-lg-mobile text-headline-lg-mobile text-on-surface md:font-headline-lg md:text-headline-lg"
			>
				{SITE_DESCRIPTION}
			</h1>
			<p class="relative z-10 max-w-2xl font-body-lg text-body-lg text-on-surface-variant">
				By a systems engineer obsessed with performance and clean architecture.
			</p>
		</header>

		<!-- Topic shortcuts -->
		{
			topics.length > 0 && (
				<section class="mb-24 pb-lg">
					<h2 class="mb-sm font-label-sm text-label-sm uppercase tracking-wider text-secondary">
						Explore Topics
					</h2>
					<div class="flex flex-wrap gap-sm font-label-sm text-label-sm uppercase">
						{topics.map((tag) => (
							<a
								href="/articles"
								class="rounded-lg border border-outline-variant bg-surface-container px-3 py-1 text-on-surface-variant transition-colors hover:border-primary hover:bg-primary/5 hover:text-primary"
							>
								{tag}
							</a>
						))}
					</div>
				</section>
			)
		}

		<!-- Latest articles -->
		<section>
			<h2
				class="mb-lg border-b border-outline-variant pb-2 font-headline-md text-headline-md text-on-surface"
			>
				Latest Articles
			</h2>

			{
				latest.length === 0 ? (
					<p class="text-on-surface-variant">No articles published yet.</p>
				) : (
					<div class="flex flex-col gap-lg">
						{latest.map((article) => (
							<article class="group rounded-xl border border-outline-variant bg-surface-container-lowest p-6 shadow-sm transition-shadow hover:shadow-md">
								<a class="block" href={`/articles/${article.id}/`}>
									<div class="mb-3 flex flex-wrap items-center gap-sm font-label-sm text-label-sm">
										<span class="text-secondary">
											<FormattedDate date={article.data.date} />
										</span>
										<span class="text-outline-variant">•</span>
										<span class="text-secondary">{readingTime(article.body)}</span>
										<span class="text-outline-variant">•</span>
										<span
											class:list={[
												'rounded-lg border border-outline-variant px-2 py-0.5 text-[11px] uppercase tracking-wider',
												difficultyBadge[article.data.difficulty],
											]}
										>
											{article.data.difficulty}
										</span>
									</div>
									<h3 class="mb-sm font-headline-md text-headline-md text-on-surface transition-colors group-hover:text-primary">
										{article.data.title}
									</h3>
									<p class="line-clamp-3 font-body-md text-body-md text-on-surface-variant">
										{article.data.description}
									</p>
								</a>
							</article>
						))}
					</div>
				)
			}

			<div class="mt-xl">
				<a
					href="/articles"
					class="inline-flex items-center gap-2 rounded-lg border border-primary/20 bg-primary-container/10 px-4 py-2 font-label-sm text-label-sm uppercase tracking-wide text-primary transition-colors hover:bg-primary-container/20"
				>
					View all articles
					<span class="material-symbols-outlined text-[18px]">arrow_right_alt</span>
				</a>
			</div>
		</section>
	</main>
</Layout>

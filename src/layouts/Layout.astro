---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
	title?: string;
	description?: string;
	/** extra classes for <body>, e.g. "dotted-bg" on the home page */
	bodyClass?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, bodyClass = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class:list={['flex min-h-screen flex-col', bodyClass]}>
		<Header />
		<slot />
		<Footer />
	</body>
</html>

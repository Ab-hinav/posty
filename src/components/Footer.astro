---
const year = new Date().getFullYear();
const links = [
	{ label: 'GitHub', href: '#' },
	{ label: 'LinkedIn', href: '#' },
	{ label: 'RSS', href: '/rss.xml' },
	{ label: 'Terms', href: '#' },
];
---

<footer class="mt-auto w-full border-t border-outline-variant bg-surface-container-low py-lg">
	<div
		class="mx-auto flex max-w-[1200px] flex-col items-center justify-between gap-md px-margin-mobile md:flex-row"
	>
		<p class="text-center font-body-md text-sm text-secondary md:text-left">
			© {year} System Journal. Confidentiality maintained through clean architecture.
		</p>
		<nav class="flex items-center gap-md font-label-sm text-label-sm uppercase">
			{
				links.map((link) => (
					<a
						href={link.href}
						class="text-on-surface-variant underline decoration-dotted underline-offset-2 transition-all duration-200 ease-in-out hover:text-primary"
					>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>
</footer>
